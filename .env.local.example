# Mission Control — environment variables
# Copy this file to .env.local and fill in your values.

# OpenClaw Gateway
# URL to your running OpenClaw gateway (check: openclaw gateway status)
GATEWAY_URL=http://127.0.0.1:18789

# Gateway auth token — found in ~/.openclaw/openclaw.json → gateway.token
# Leave empty if your gateway has no auth configured.
GATEWAY_TOKEN=your_gateway_token_here

# Workspace path — defaults to ~/.openclaw/workspace if not set
# WORKSPACE_PATH=/Users/you/.openclaw/workspace
